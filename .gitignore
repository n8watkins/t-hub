# Dependencies
node_modules/
# Also ignore a `node_modules` SYMLINK (worktrees symlink it); the trailing
# slash above only matches a real directory, so the symlink would otherwise be
# picked up by `git add -A` and committed with a machine-specific target.
node_modules
.pnpm-store/

# Build output
dist/
dist-ssr/
*.local

# Local convenience symlink to the bundled Claude Code binary (machine-specific
# target under node_modules; created for dev, never committed).
apps/desktop/bin/

# Rust / Tauri (now nested under the desktop app in the monorepo)
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/

# The `th` CLI crate's build output.
apps/cli/target/

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.log

# Env
.env
.env.*
!.env.example
